{
  "version": "0.0.1",
  "configurations": [
    {
      "name": "api",
      "runtimeExecutable": "npm",
      "runtimeArgs": [
        "run",
        "dev"
      ],
      "port": 3000
    },
    {
      "name": "web",
      "runtimeExecutable": "npm",
      "runtimeArgs": [
        "--prefix",
        "web",
        "run",
        "dev"
      ],
      "port": 3001
    },
    {
      "name": "api-test",
      "runtimeExecutable": "env",
      "runtimeArgs": [
        "PORT=3010",
        "WHATSAPP_DISABLED=1",
        "npm",
        "run",
        "dev"
      ],
      "port": 3010
    },
    {
      "name": "web-test",
      "runtimeExecutable": "env",
      "runtimeArgs": [
        "API_BASE_URL=http://localhost:3010",
        "npm",
        "--prefix",
        "web",
        "run",
        "dev",
        "--",
        "-p",
        "3012"
      ],
      "port": 3012
    },
    {
      "name": "web-alt",
      "runtimeExecutable": "npm",
      "runtimeArgs": [
        "--prefix",
        "web",
        "run",
        "dev",
        "--",
        "-p",
        "3002"
      ],
      "port": 3002
    },
    {
      "name": "web-preview",
      "runtimeExecutable": "npm",
      "runtimeArgs": [
        "--prefix",
        "web",
        "run",
        "dev",
        "--",
        "-p",
        "3005"
      ],
      "port": 3005
    },
    {
      "name": "web-verify",
      "runtimeExecutable": "npm",
      "runtimeArgs": [
        "--prefix",
        "web",
        "run",
        "dev",
        "--",
        "-p",
        "3007"
      ],
      "port": 3007
    }
  ]
}
