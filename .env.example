# GEMINI_API_KEY: Required for Gemini AI API calls.
# AI Studio automatically injects this at runtime from user secrets.
# Users configure this via the Secrets panel in the AI Studio UI.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"

# GOOGLE_MAPS_PLATFORM_KEY: Required for loading real Google Maps inside the viewer.
GOOGLE_MAPS_PLATFORM_KEY=""

# JWT_SECRET: Secret key for signing JSON Web Tokens used in Admin & Operator logins
JWT_SECRET=""

# ENTERPRISE POSTGRESQL DATABASE URL (If missing, system falls back to Local SQLite)
DATABASE_URL="postgresql://user:password@localhost:5432/gedekgorek"

# REDIS CACHE URL (Used for high-traffic endpoints and Search Query caching)
REDIS_URL="redis://localhost:6379"

# LIBRETRANSLATE_URL: Self-hosted LibreTranslate instance used to auto-translate tour
# name/description (source: Azerbaijani) into EN/RU when a tour is created or edited.
# Run locally with: docker compose -f docker-compose.libretranslate.yml up -d
LIBRETRANSLATE_URL="http://localhost:5050"
# LIBRETRANSLATE_API_KEY: Only needed if the instance has LT_API_KEYS enabled.
LIBRETRANSLATE_API_KEY=""