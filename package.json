{
  "name": "gedekgorek-api",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "tsx server.ts",
    "dev:all": "concurrently -n api,web -c blue,green \"npm run dev\" \"npm run dev:web\"",
    "start": "tsx server.ts",
    "dev:web": "npm --prefix web run dev",
    "build:web": "npm --prefix web run build",
    "start:web": "npm --prefix web run start",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit",
    "test:api": "vitest run -c vitest.config.api.ts"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1090.0",
    "@google/genai": "^1.29.0",
    "@hapi/boom": "^10.0.1",
    "@types/pg": "^8.20.0",
    "@whiskeysockets/baileys": "^7.0.0-rc13",
    "bcryptjs": "^3.0.3",
    "cors": "^2.8.5",
    "dotenv": "^17.2.3",
    "express": "^4.21.2",
    "jsonwebtoken": "^9.0.3",
    "jspdf": "^4.2.1",
    "multer": "^2.2.0",
    "nodemailer": "^9.0.3",
    "pg": "^8.21.0",
    "pino": "^10.3.1",
    "qrcode": "^1.5.4",
    "resend": "^6.17.2"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@types/bcryptjs": "^2.4.6",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/multer": "^2.2.0",
    "@types/node": "^22.14.0",
    "@types/nodemailer": "^8.0.1",
    "@types/qrcode": "^1.5.6",
    "concurrently": "^10.0.3",
    "esbuild": "^0.25.0",
    "eslint": "^9.39.4",
    "globals": "^17.7.0",
    "tsx": "^4.21.0",
    "typescript": "~5.8.2",
    "typescript-eslint": "^8.62.1",
    "vitest": "^4.1.9"
  }
}
