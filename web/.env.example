# ─── API wiring ───────────────────────────────────────────────────────────────
# API_BASE_URL: used by Server Components (SSR data fetching) and by next.config.ts
# rewrites. Points at the Express API origin. Can be an INTERNAL url in prod (e.g. the
# service-to-service address) since it is never exposed to the browser.
API_BASE_URL="http://localhost:3000"

# NEXT_PUBLIC_API_BASE_URL: only needed if browser code must build an ABSOLUTE api url.
# Normally the browser uses relative /api/* (proxied by the rewrite), so this can mirror
# API_BASE_URL or be left as the public origin.
NEXT_PUBLIC_API_BASE_URL="http://localhost:3000"

# ─── SEO / canonical ────────────────────────────────────────────────────────────
# NEXT_PUBLIC_SITE_URL: public origin of THIS Next app. Used for canonical + OG:url +
# JSON-LD. Replaces the previously hardcoded https://gedekgorek.com in TourDetailRoute.
NEXT_PUBLIC_SITE_URL="http://localhost:3001"

# ─── Images ──────────────────────────────────────────────────────────────────────
# Comma-separated https hostnames allowed for next/image (CDN, staging image host, etc.).
NEXT_PUBLIC_IMAGE_HOSTS=""

# ─── Client-side keys (mirrors of what the old Vite app injected) ────────────────
# Google Maps JS key for the in-browser map viewer (client-only).
NEXT_PUBLIC_GOOGLE_MAPS_PLATFORM_KEY=""
